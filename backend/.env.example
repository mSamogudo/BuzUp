SECRET_KEY=buzup-dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3008,http://localhost:3008
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3008,http://localhost:3008
PUBLIC_BASE_URL=http://127.0.0.1:3008

POSTGRES_DB=buzup_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Payment Gateway: AUTO or MOCK
PAYMENT_GATEWAY_PROVIDER=AUTO
PAYMENT_GATEWAY_WEBHOOK_SECRET=buzup-webhook-secret-dev
PAYMENT_MOBILE_WALLET_METHODS=MPESA,EMOLA
PAYMENT_MOBILE_WALLET_TIMEOUT_SECONDS=180
PAYLESS_BASE_URL=https://payless.bluteki.com/api/v2.0
PAYLESS_BEARER_TOKEN=

# M-Pesa via Payless
MPESA_TRANSPORT=PAYLESS
MPESA_C2B_URL=
MPESA_API_URL=
MPESA_QUERY_URL=
MPESA_BEARER_TOKEN=
MPESA_API_KEY=
MPESA_API_SECRET=
MPESA_SERVICE_PROVIDER_CODE=
MPESA_SHORTCODE=
MPESA_SERVICE=buzup
MPESA_DESCRIPTION=Pagamento BuzUp
MPESA_CALLBACK_URL=

# E-Mola via Payless
EMOLA_TRANSPORT=PAYLESS
EMOLA_C2B_URL=
EMOLA_API_URL=
EMOLA_QUERY_URL=
EMOLA_BEARER_TOKEN=
EMOLA_API_KEY=
EMOLA_API_SECRET=
EMOLA_WALLET_CODE=
EMOLA_SMS_CONTENT=Confirme o pagamento BuzUp na sua carteira E-Mola.
EMOLA_SERVICE=buzup
EMOLA_DESCRIPTION=Pagamento BuzUp

# SMS via Bluteki
BLUTEKI_BASE_URL=https://smshub.bluteki.com/api/v1
BLUTEKI_API_KEY=
BLUTEKI_SENDER_ID=UpDigital
BLUTEKI_CUSTOMER_KEY=
BLUTEKI_USERNAME=
BLUTEKI_PASSWORD=
BLUTEKI_DEFAULT_CAMPAIGN_ID=
BLUTEKI_DEFAULT_MESSAGE_TYPE=AUTO
BLUTEKI_USE_GET=false
BLUTEKI_VERIFY_SSL=true

# SMS_PROVIDER: BLUTEKI or MOCK
SMS_PROVIDER=BLUTEKI

OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_WINDOW_SECONDS=300
OTP_MAX_REQUESTS_PER_PHONE=3
OTP_MAX_REQUESTS_PER_IP=20
